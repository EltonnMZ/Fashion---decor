function pageHTML(){
  const isAdmin=S.role==='admin';
  if(S.page==='monitor')    return isAdmin?monitorHTML():'';
  if(S.page==='stock')      return stockHTML(isAdmin);
  if(S.page==='aluguer')    return aluguerHTML(isAdmin);
  if(S.page==='cotacoes')   return isAdmin?cotacoesHTML():'';
  if(S.page==='definicoes') return isAdmin?definicoesHTML():'';
  return '';
}
function bindPage(){
  const isAdmin=S.role==='admin';
  if(S.page==='stock')      bindStock(isAdmin);
  if(S.page==='aluguer')    bindAluguer(isAdmin);
  if(S.page==='cotacoes'&&isAdmin) bindCotacoes();
  if(S.page==='definicoes'&&isAdmin) bindDefinicoes();
}

