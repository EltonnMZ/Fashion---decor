    ${isCot?`<div style="display:flex;justify-content:flex-end;margin-bottom:40px"><div style="background:#3B1F0A;color:#D4A017;padding:10px 18px;font-size:16px;display:flex;gap:40px;min-width:220px;justify-content:space-between"><span>TOTAL</span><span>${fmtMZN(doc.total)}</span></div></div>`:''}
    ${!isCot&&doc.valorTotal?`
    <div style="display:flex;justify-content:flex-end;margin-bottom:20px">
      <div style="font-family:system-ui;font-size:12px;min-width:260px">
        <div style="display:flex;justify-content:space-between;padding:6px 12px;background:#F5EDD8"><span>Valor total</span><strong>${fmtMZN(doc.valorTotal)}</strong></div>
        <div style="display:flex;justify-content:space-between;padding:6px 12px;color:#4A7A3A"><span>Valor pago</span><strong>${fmtMZN(doc.valorPago||0)}</strong></div>
        <div style="display:flex;justify-content:space-between;padding:6px 12px;background:#3B1F0A;color:#D4A017"><span>Valor em falta</span><strong>${fmtMZN(Math.max(0,(doc.valorTotal||0)-(doc.valorPago||0)))}</strong></div>
      </div>
    </div>`:''}
    <div style="display:flex;justify-content:space-between;margin-top:40px;font-family:system-ui;font-size:11px;color:#7A6040;page-break-inside:avoid;">
      <div style="text-align:center;width:42%"><div style="border-top:1px solid #3B1F0A;padding-top:6px">Assinatura — Fashion Decor</div></div>
      <div style="text-align:center;width:42%"><div style="border-top:1px solid #3B1F0A;padding-top:6px">Assinatura — Cliente</div></div>
    </div>
    <div style="margin-top:24px;font-size:8px;color:#C9B48A;font-family:system-ui;text-align:center;border-top:1px solid #E8DCC8;padding-top:8px;page-break-inside:avoid;">© ${yr} Fashion Decor · Todos os direitos reservados · (FDC)</div>
  </div>`;}

window.pCot=id=>{
  const c=S.cotacoes.find(x=>x.id===id);if(!c)return;
  const itens=S.cotItens.filter(i=>i.cotacao_id===id).map(i=>({nome:i.nome,qtd:i.quantidade,preco:i.preco_unit}));
  document.getElementById('pa').innerHTML=buildPrint({tipo:'cotacao',numero:id.slice(0,6).toUpperCase(),data:c.criado_em?c.criado_em.slice(0,10):'—',cliente:c.cliente,evento:c.evento,itens,total:c.total});
  // Suprimir URL e cabeçalhos do browser via estilo injectado
  const sty=document.createElement('style');
  sty.id='print-override';
  sty.textContent='@page{margin:0;size:A4 portrait;}@page :first{margin:0;}@page :left{margin:0;}@page :right{margin:0;}@media print{body>*{display:none!important;}#pa{display:block!important;position:absolute;left:0;top:0;width:100%;padding:15mm 18mm;background:#fff;}}';
  document.head.appendChild(sty);
  setTimeout(()=>{window.print();setTimeout(()=>{const s=document.getElementById('print-override');if(s)s.remove();},500);},150);};
window.pRecibo=id=>{
  const a=S.alugueis.find(x=>x.id===id);if(!a)return;
  const itens=S.aluguerItens.filter(i=>i.aluguer_id===id).map(i=>({nome:i.nome,qtd:i.quantidade}));
  document.getElementById('pa').innerHTML=buildPrint({tipo:'recibo',numero:id.slice(0,6).toUpperCase(),data:a.data_saida||today(),cliente:a.cliente,armazem:a.armazem,dataPrevista:a.data_prevista,valorTotal:a.valor_total,valorPago:a.valor_pago,itens:itens.length>0?itens:[{nome:'—',qtd:1}]});
  const sty=document.createElement('style');
  sty.id='print-override';
  sty.textContent='@page{margin:0;size:A4 portrait;}@page :first{margin:0;}@page :left{margin:0;}@page :right{margin:0;}@media print{body>*{display:none!important;}#pa{display:block!important;position:absolute;left:0;top:0;width:100%;padding:15mm 18mm;background:#fff;}}';
  document.head.appendChild(sty);
  setTimeout(()=>{window.print();setTimeout(()=>{const s=document.getElementById('print-override');if(s)s.remove();},500);},150);};

// ══════════════════════════════════════════════
// PWA MANIFEST
// ══════════════════════════════════════════════
const mf={name:"Fashion Decor",short_name:"FashionDecor",start_url:".",display:"standalone",background_color:"#2C1506",theme_color:"#2C1506",icons:[{src:"data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 192 192'%3E%3Crect width='192' height='192' rx='38' fill='%232C1506'/%3E%3Ccircle cx='96' cy='96' r='72' fill='%23D4A017'/%3E%3Ctext x='96' y='120' text-anchor='middle' font-size='60' font-weight='900' font-family='Georgia' fill='%233B1F0A'%3EFD%3C/text%3E%3C/svg%3E",sizes:"192x192",type:"image/svg+xml"}]};
const mb=new Blob([JSON.stringify(mf)],{type:'application/json'});
const ml=document.createElement('link');ml.rel='manifest';ml.href=URL.createObjectURL(mb);document.head.appendChild(ml);

// ══════════════════════════════════════════════
// BOOT
// ══════════════════════════════════════════════
render();
</script>
