function aluguerHTML(isAdmin=true){
  const ec=S.alugueis.filter(a=>a.status==='Em curso');
  const dv=S.alugueis.filter(a=>a.status==='Devolvido');
  const getItens=aid=>S.aluguerItens.filter(i=>i.aluguer_id===aid);

  // ── Vista simplificada para funcionária ──
  if(!isAdmin){
    const mkFuncCards=rows=>rows.map(a=>{
      const itens=getItens(a.id);
      return`
    <div class="card"><div class="cp">
      <div class="li-r">
        <div>
          <div class="li-t">${a.cliente}</div>
          ${a.evento?`<div class="li-s" style="color:var(--warn);font-size:11px">${a.evento}</div>`:''}
        </div>
        <div class="li-s">${a.armazem}</div>
      </div>
      <div style="margin-top:8px">
        ${itens.map(it=>`<div style="display:flex;justify-content:space-between;font-size:12px;padding:3px 0;border-bottom:1px dashed #EFE5D0">
          <span>${it.nome}</span><span style="font-weight:700">${it.quantidade}</span>
        </div>`).join('')}
      </div>
      <div style="font-size:12px;color:var(--mid);margin-top:6px;padding-top:6px;border-top:1px solid #EFE5D0">
        Saída: ${a.data_saida||'—'} · Devolução prevista: ${a.data_prevista||'a definir'}
      </div>
    </div></div>`}).join('')||`<div class="card"><div class="cp" style="text-align:center;padding:28px;color:var(--border)">Nenhum material fora do armazém.</div></div>`;
    return`
    <p style="font-size:12px;color:var(--mid);margin-bottom:12px">Material actualmente fora dos armazéns — vista de consulta.</p>
    ${mkFuncCards(ec)}
    ${dv.length>0?`
    <div style="font-size:11px;color:var(--mid);font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin:16px 0 8px">Devolvidos recentemente (${dv.length})</div>
    ${mkFuncCards(dv)}`:''}`;
  }

  if(!S.fitensAl) S.fitensAl=[];

  const form=S.showForm?`
  <div class="fb">
    ${S.ferr?`<div class="alert">${S.ferr}</div>`:''}

    <div class="fg g2">
      <div class="s2"><label class="lbl">Cliente *</label><input class="inp" id="f-cli" placeholder="Nome do cliente" value="${S.fd.cliente||''}"/></div>
      <div><label class="lbl">Data saída</label><input class="inp" id="f-saida" type="date" value="${S.fd.data_saida||today()}" oninput="saveFormState();recalcTotal()"/></div>
      <div><label class="lbl">Devolução prevista</label><input class="inp" id="f-prev" type="date" value="${S.fd.data_prevista||''}" oninput="saveFormState();recalcTotal()"/></div>
      <div><label class="lbl">Armazém</label>
        <select class="inp" id="f-arm">
          ${ARMAZENS.map(a=>`<option value="${a}" ${S.fd.armazem===a?'selected':''}>${a}</option>`).join('')}
        </select>
      </div>
      <div class="s2"><label class="lbl">Evento / Local</label>
        <input class="inp" id="f-evt" placeholder='ex: "Casamento · Jardim dos Namorados"' value="${S.fd.evento||''}"/>
      </div>
    </div>

    <div style="border-top:1px solid var(--border);margin:12px 0;padding-top:12px">
      <div style="font-size:11px;color:var(--gold);font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px">Artigos do aluguer</div>
      ${S.ierr?`<div class="alert">${S.ierr}</div>`:''}
      <div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap;align-items:flex-end">
        <div style="flex:2;min-width:140px">
          <label class="lbl">Artigo</label>
          <select class="inp" id="f-art">
            <option value="">Seleccionar...</option>
            ${S.stock.map(s=>`<option value="${s.id}">${s.nome}</option>`).join('')}
          </select>
        </div>
        <div style="width:80px">
          <label class="lbl">Qtd</label>
          <input class="inp" id="f-qtd" type="number" min="1" value="1"/>
        </div>
        <div id="disp-box" style="font-size:12px;color:var(--mid);padding-bottom:10px"></div>
        <button class="btn bgh bsm" id="btn-add-linha" style="margin-bottom:1px">+ Adicionar</button>
      </div>

      ${S.fitensAl.length>0?`
      <div style="border:1px solid var(--border);border-radius:6px;overflow:hidden;margin-bottom:12px">
        ${S.fitensAl.map((it,i)=>`
        <div style="display:flex;justify-content:space-between;align-items:center;padding:9px 12px;border-bottom:1px solid #EFE5D0;font-size:13px">
          <div>
            <div style="font-weight:600;color:var(--dark)">${it.nome}</div>
            <div style="font-size:11px;color:var(--mid)">${it.armazem} · ${fmtMZN(it.preco)}/un./dia</div>
          </div>
          <div style="display:flex;align-items:center;gap:10px">
            <div style="text-align:right">
              <div style="font-weight:700">× ${it.qtd}</div>
              <div style="font-size:11px;color:var(--gold);font-weight:600">${fmtMZN(it.preco*it.qtd*Math.max(1,Math.round((new Date(S.fd.data_prevista||S.fd.data_saida||today())-new Date(S.fd.data_saida||today()))/(86400000))))}</div>
            </div>
            <button onclick="rmAlItem(${i})" style="color:var(--danger)">${I.x}</button>
          </div>
        </div>`).join('')}
        <div style="padding:10px 12px;background:var(--row-head);display:flex;justify-content:space-between;align-items:center">
          <span style="font-size:12px;color:var(--mid)">${S.fitensAl.length} artigo${S.fitensAl.length>1?'s':''} · ${S.fitensAl.reduce((s,i)=>s+i.qtd,0)} unidades</span>
          <span style="font-size:15px;font-weight:700;color:var(--dark);font-family:Georgia,serif">
            ${(()=>{const d=Math.max(1,Math.round((new Date(S.fd.data_prevista||S.fd.data_saida||today())-new Date(S.fd.data_saida||today()))/(86400000)));return fmtMZN(S.fitensAl.reduce((s,i)=>s+(i.preco*i.qtd*d),0));})()}
          </span>
        </div>
      </div>`:''}
    </div>

    <div style="border-top:1px solid var(--border);margin:12px 0;padding-top:12px">
      <div style="font-size:11px;color:var(--gold);font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px">Pagamento</div>
      <div class="fg g2">
        <div>
          <label class="lbl">Valor total (MT)
            ${S.fitensAl.length>0&&S.fd.data_saida&&S.fd.data_prevista?
              `<span id="dias-label" style="color:var(--gold);font-weight:700;margin-left:6px">
                ${Math.max(1,Math.round((new Date(S.fd.data_prevista)-new Date(S.fd.data_saida))/86400000))} dia${Math.max(1,Math.round((new Date(S.fd.data_prevista)-new Date(S.fd.data_saida))/86400000))!==1?'s':''}
              </span>`:''}
          </label>
          <input class="inp" id="f-total" type="number" min="0" placeholder="0.00"
            value="${(()=>{const d=S.fd.data_saida&&S.fd.data_prevista?Math.max(1,Math.round((new Date(S.fd.data_prevista)-new Date(S.fd.data_saida))/86400000)):1;return S.fitensAl.length>0?(S.fitensAl.reduce((s,i)=>s+(i.preco*i.qtd*d),0)).toFixed(2):S.fd.valor_total||'';})()}"
            oninput="S.fd.valor_total=this.value;calcPag()"
            style="background:var(--row-head);color:var(--dark);font-weight:700"/>
          <div style="font-size:11px;color:var(--mid);margin-top:3px">Qtd × Preço/dia × Nº dias · editável se houver desconto</div>
        </div>
        <div>
          <label class="lbl">Valor já pago (MT)</label>
          <input class="inp" id="f-pago" type="number" min="0" placeholder="0.00" value="${S.fd.valor_pago||''}" oninput="calcPag()"/>
        </div>
      </div>
      <div id="pag-calc" style="display:none;background:#FAF4E8;border:1px solid var(--border);border-radius:6px;padding:12px;margin-top:4px">
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;text-align:center">
          <div><div style="font-size:10px;color:var(--mid);text-transform:uppercase;letter-spacing:.07em;margin-bottom:4px">Total</div>
            <div id="pc-total" style="font-size:16px;font-weight:700;color:var(--dark);font-family:Georgia,serif"></div></div>
          <div><div style="font-size:10px;color:var(--success);text-transform:uppercase;letter-spacing:.07em;margin-bottom:4px">Pago</div>
            <div id="pc-pago" style="font-size:16px;font-weight:700;color:var(--success);font-family:Georgia,serif"></div></div>
          <div><div style="font-size:10px;color:var(--danger);text-transform:uppercase;letter-spacing:.07em;margin-bottom:4px">Falta</div>
            <div id="pc-falta" style="font-size:16px;font-weight:700;font-family:Georgia,serif"></div></div>
        </div>
        <div style="margin-top:10px">
          <div style="background:#EFE5D0;border-radius:99px;height:8px;overflow:hidden">
            <div id="pc-bar" style="height:100%;background:var(--success);border-radius:99px;transition:width .3s;width:0%"></div>
          </div>
          <div id="pc-pct" style="text-align:center;font-size:11px;color:var(--mid);margin-top:4px"></div>
        </div>
      </div>
    </div>

    <div style="display:flex;gap:8px">
      <button class="btn bd bsm" id="btn-add-al">Registar aluguer</button>
      <button class="btn bgh bsm" onclick="S.showForm=false;S.fitensAl=[];render()">Cancelar</button>
    </div>
  </div>`:'';

  const pagInfo=a=>{
    const t=Number(a.valor_total)||0;const p=Number(a.valor_pago)||0;
    const f=Math.max(0,t-p);const pct=t>0?Math.min(100,Math.round(p/t*100)):0;
    return{t,p,f,pct};
  };

  const mkTable=rows=>`<div class="card" style="overflow-x:auto"><table class="tbl"><thead><tr>
    <th>Cliente</th><th>Artigos</th><th>Armazém</th><th>Evento/Local</th>
    <th class="r">Total</th><th class="r">Pago</th><th class="r">Falta</th>
    <th>Saída</th><th>Dev. prevista</th><th></th>
  </tr></thead><tbody>
  ${rows.map(a=>{const itens=getItens(a.id);const pg=pagInfo(a);return`
  <tr>
    <td class="b">${a.cliente}</td>
    <td style="font-size:12px">${itens.length>0?itens.map(i=>`${i.nome} ×${i.quantidade}`).join('<br>'):'—'}</td>
    <td class="m">${a.armazem}</td>
    <td class="m" style="font-size:12px">${a.evento||'—'}</td>
    <td class="r m">${pg.t>0?fmtMZN(pg.t):'—'}</td>
    <td class="r" style="color:var(--success);font-weight:600">${pg.p>0?fmtMZN(pg.p):'—'}</td>
    <td class="r" style="font-weight:600;color:${pg.t>0?(pg.f>0?'var(--danger)':'var(--success)'):'var(--mid)'}">
      ${pg.t>0?(pg.f>0?fmtMZN(pg.f)+' ('+pg.pct+'%)':'Pago'):'—'}
    </td>
    <td class="m">${a.data_saida||'—'}</td><td class="m">${a.data_prevista||'—'}</td>
    <td style="white-space:nowrap;text-align:right">
      <button onclick="pRecibo('${a.id}')" style="color:var(--gold);margin-right:4px">${I.print}</button>
      ${a.status==='Em curso'?`<button onclick="devAl('${a.id}')" style="color:var(--success);margin-right:4px">${I.check}</button>`:''}
      <button onclick="delAl('${a.id}')" style="color:var(--border)">${I.trash}</button>
    </td>
  </tr>`}).join('')}
  ${rows.length===0?`<tr><td colspan="10" style="text-align:center;padding:28px;color:var(--border)">Sem registos.</td></tr>`:''}
  </tbody></table></div>`;

  const mkCards=rows=>rows.map(a=>{
    const itens=getItens(a.id);const pg=pagInfo(a);return`
  <div class="card"><div class="cp">
    <div class="li-r">
      <div>
        <div class="li-t">${a.cliente}</div>
        <div class="li-s">${a.armazem}${a.data_saida?' · '+a.data_saida:''}</div>
        ${a.evento?`<div class="li-s" style="color:var(--warn);font-size:11px">${a.evento}</div>`:''}
      </div>
      <div style="display:flex;gap:8px;align-items:center">
        <button onclick="pRecibo('${a.id}')" style="color:var(--gold)">${I.print}</button>
        ${a.status==='Em curso'?`<button onclick="devAl('${a.id}')" style="color:var(--success)">${I.check}</button>`:''}
        <button onclick="delAl('${a.id}')" style="color:var(--border)">${I.trash}</button>
      </div>
    </div>
    ${itens.length>0?`
    <div style="margin-top:8px;border-top:1px solid #EFE5D0;padding-top:8px">
      ${itens.map(it=>`<div style="display:flex;justify-content:space-between;font-size:12px;padding:3px 0;border-bottom:1px dashed #EFE5D0">
        <span style="color:var(--dark)">${it.nome}</span><span style="font-weight:700">× ${it.quantidade}</span>
      </div>`).join('')}
    </div>`:''}
    ${pg.t>0?`
    <div style="margin-top:10px;border-top:1px solid #EFE5D0;padding-top:10px">
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;text-align:center;margin-bottom:8px">
        <div><div style="font-size:9px;color:var(--mid);text-transform:uppercase;margin-bottom:2px">Total</div>
          <div style="font-size:13px;font-weight:700;color:var(--dark)">${fmtMZN(pg.t)}</div></div>
        <div><div style="font-size:9px;color:var(--success);text-transform:uppercase;margin-bottom:2px">Pago</div>
          <div style="font-size:13px;font-weight:700;color:var(--success)">${fmtMZN(pg.p)}</div></div>
        <div><div style="font-size:9px;color:var(--danger);text-transform:uppercase;margin-bottom:2px">Falta</div>
          <div style="font-size:13px;font-weight:700;color:${pg.f>0?'var(--danger)':'var(--success)'}">
            ${pg.f>0?fmtMZN(pg.f):'Pago'}</div></div>
      </div>
      <div style="background:#EFE5D0;border-radius:99px;height:6px;overflow:hidden">
        <div style="height:100%;width:${pg.pct}%;background:${pg.pct>=100?'var(--success)':pg.pct>=50?'var(--gold)':'var(--danger)'};border-radius:99px"></div>
      </div>
      <div style="text-align:center;font-size:11px;color:var(--mid);margin-top:3px">${pg.pct}% pago</div>
    </div>`:''}
    <div style="font-size:12px;color:var(--mid);margin-top:6px">Dev.: ${a.data_prevista||'a definir'}</div>
  </div></div>`}).join('')||`<div class="card"><div class="cp" style="text-align:center;padding:24px;color:var(--border)">Sem registos.</div></div>`;

  return`${form}
  <div style="font-size:11px;color:var(--mid);font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:8px">Em curso (${ec.length})</div>
  ${isMobile()?mkCards(ec):mkTable(ec)}
  <div style="font-size:11px;color:var(--mid);font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin:16px 0 8px">Devoluções (${dv.length})</div>
  ${isMobile()?mkCards(dv):mkTable(dv)}`;}

function bindAluguer(isAdmin=true){
  if(!isAdmin)return;
  if(!S.fitensAl)S.fitensAl=[];

  const as=document.getElementById('f-art');
  const am=document.getElementById('f-arm');
  const upD=()=>{
    const ai=as?as.value:'';const arm=am?am.value:ARMAZENS[0];
    const art=S.stock.find(s=>s.id===ai);
    const d=art?(arm===ARMAZENS[0]?art.qtd_cidade:art.qtd_matola):'—';
    const el=document.getElementById('disp-box');
    if(el)el.innerHTML=ai?`Disponível: <strong style="color:var(--dark);font-size:14px;margin-left:4px">${d}</strong>`:'';
  };
  if(as)as.onchange=e=>{upD();};
  if(am)am.onchange=e=>{upD();};
  upD();

  // Função para guardar estado actual do formulário no S.fd
  const saveFormState=()=>{
    S.fd.cliente    = document.getElementById('f-cli')?.value.trim()||S.fd.cliente||'';
    S.fd.armazem    = document.getElementById('f-arm')?.value||S.fd.armazem||ARMAZENS[0];
    S.fd.data_saida = document.getElementById('f-saida')?.value||S.fd.data_saida||today();
    S.fd.data_prevista = document.getElementById('f-prev')?.value||S.fd.data_prevista||'';
    S.fd.evento     = document.getElementById('f-evt')?.value.trim()||S.fd.evento||'';
    S.fd.valor_total= document.getElementById('f-total')?.value||S.fd.valor_total||'';
    S.fd.valor_pago = document.getElementById('f-pago')?.value||S.fd.valor_pago||'';
  };

  // Botão adicionar linha de artigo
  const btnLi=document.getElementById('btn-add-linha');
  if(btnLi)btnLi.onclick=()=>{
    saveFormState(); // ← guarda tudo antes de re-renderizar
    const ai=document.getElementById('f-art').value;
    const arm=S.fd.armazem;
    const qtd=Number(document.getElementById('f-qtd').value)||0;
    if(!ai){S.ierr='Seleccione um artigo.';render();return;}
    if(qtd<=0){S.ierr='Quantidade deve ser maior que zero.';render();return;}
    const art=S.stock.find(s=>s.id===ai);
    const disp=art?(arm===ARMAZENS[0]?art.qtd_cidade:art.qtd_matola):0;
    if(qtd>disp){S.ierr=`Stock insuficiente em ${arm}. Disponível: ${disp}.`;render();return;}
    const existe=S.fitensAl.find(i=>i.artigo_id===ai&&i.armazem===arm);
    if(existe){S.ierr='Artigo já adicionado. Remove e readiciona com a quantidade correcta.';render();return;}
    S.ierr='';
    const dias=S.fd.data_saida&&S.fd.data_prevista?Math.max(1,Math.round((new Date(S.fd.data_prevista)-new Date(S.fd.data_saida))/86400000)):1;
    const totalAl=S.fitensAl.reduce((s,i)=>s+(i.preco*i.qtd*dias),0)+(art.preco*qtd*dias);
    S.fd.valor_total=totalAl.toFixed(2);
    S.fitensAl.push({artigo_id:ai,nome:art.nome,qtd,armazem:arm,disp,preco:art.preco||0});
    render();
  };

  // Botão guardar aluguer
  const btn=document.getElementById('btn-add-al');
  if(!btn)return;
  btn.onclick=async()=>{
    saveFormState(); // ← guardar estado antes de validar
    const cli=S.fd.cliente;
    const arm=S.fd.armazem;
    const saida=S.fd.data_saida;
    const prev=S.fd.data_prevista;
    const evt=S.fd.evento;
    const vTotal=Number(S.fd.valor_total)||0;
    const vPago=Number(S.fd.valor_pago)||0;
    if(!cli){S.ferr='Indique o nome do cliente.';render();return;}
    if(S.fitensAl.length===0){S.ferr='Adicione pelo menos um artigo.';render();return;}
    if(vPago>vTotal&&vTotal>0){S.ferr='O valor pago não pode ser superior ao total.';render();return;}
    btn.disabled=true;btn.textContent='A guardar...';
    try{
      const [al]=await DB.addAluguer({cliente:cli,armazem:arm,data_saida:saida||null,data_prevista:prev||null,evento:evt||null,valor_total:vTotal||null,valor_pago:vPago||null,status:'Em curso'});
      await Promise.all(S.fitensAl.map(it=>DB.addAluguerItem({aluguer_id:al.id,artigo_id:it.artigo_id,nome:it.nome,quantidade:it.qtd,armazem:it.armazem})));
      S.ferr='';S.showForm=false;S.fitensAl=[];await loadAll();
    }catch(e){S.ferr='Erro: '+e.message;render();btn.disabled=false;}
  };
}
window.rmAlItem=i=>{
  if(!S.fitensAl)S.fitensAl=[];
  // Guardar estado do formulário antes de re-renderizar
  S.fd.cliente       = document.getElementById('f-cli')?.value.trim()||S.fd.cliente||'';
  S.fd.armazem       = document.getElementById('f-arm')?.value||S.fd.armazem||ARMAZENS[0];
  S.fd.data_saida    = document.getElementById('f-saida')?.value||S.fd.data_saida||today();
  S.fd.data_prevista = document.getElementById('f-prev')?.value||S.fd.data_prevista||'';
  S.fd.evento        = document.getElementById('f-evt')?.value.trim()||S.fd.evento||'';
  S.fd.valor_total   = document.getElementById('f-total')?.value||S.fd.valor_total||'';
  S.fd.valor_pago    = document.getElementById('f-pago')?.value||S.fd.valor_pago||'';
  S.fitensAl.splice(i,1);
  const dias=S.fd.data_saida&&S.fd.data_prevista?Math.max(1,Math.round((new Date(S.fd.data_prevista)-new Date(S.fd.data_saida))/86400000)):1;
  const novoTotal=S.fitensAl.reduce((s,it)=>s+(it.preco*it.qtd*dias),0);
  S.fd.valor_total=novoTotal>0?novoTotal.toFixed(2):'';
  render();
};
// Calcula número de dias entre saída e devolução
window.calcDias=()=>{
  const s=document.getElementById('f-saida')?.value;
  const p=document.getElementById('f-prev')?.value||S.fd.data_prevista;
  if(!s||!p)return 1;
  const diff=Math.round((new Date(p)-new Date(s))/(1000*60*60*24));
  return diff>0?diff:1;
};
// Recalcula total com base em qty × preco × dias
window.recalcTotal=()=>{
  const dias=window.calcDias();
  const total=S.fitensAl.reduce((s,i)=>s+(i.preco*i.qtd*dias),0);
  S.fd.valor_total=total>0?total.toFixed(2):'';
  // Actualizar campo visual
  const el=document.getElementById('f-total');
  if(el)el.value=S.fd.valor_total;
  // Actualizar label de dias
  const dl=document.getElementById('dias-label');
  if(dl)dl.textContent=dias+' dia'+( dias!==1?'s':'');
  calcPag();
};
window.calcPag=()=>{
  const t=Number(document.getElementById('f-total')?.value)||0;
  const p=Number(document.getElementById('f-pago')?.value)||0;
  const box=document.getElementById('pag-calc');
  if(!box)return;
  if(t<=0&&p<=0){box.style.display='none';return;}
  box.style.display='block';
  const falta=Math.max(0,t-p);
  const pct=t>0?Math.min(100,Math.round(p/t*100)):0;
  document.getElementById('pc-total').textContent=fmtMZN(t);
  document.getElementById('pc-pago').textContent=fmtMZN(p);
  const fe=document.getElementById('pc-falta');
  fe.textContent=falta>0?fmtMZN(falta):'Liquidado';
  fe.style.color=falta>0?'var(--danger)':'var(--success)';
  document.getElementById('pc-bar').style.width=pct+'%';
  document.getElementById('pc-bar').style.background=pct>=100?'var(--success)':pct>=50?'var(--gold)':'var(--danger)';
  document.getElementById('pc-pct').textContent=pct+'% pago'+(pct>=100?' — liquidado!':'');
};
window.devAl=async id=>{
  try{await DB.updAluguer(id,{status:'Devolvido'});await loadAll();}
  catch(e){alert('Erro: '+e.message);}
};
window.delAl=async id=>{
  if(!confirm('Remover registo?'))return;
  try{await DB.delAluguerItens(id);await DB.delAluguer(id);await loadAll();}catch(e){alert('Erro: '+e.message);}
};

