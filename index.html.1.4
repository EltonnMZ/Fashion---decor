      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px">
        <div><div class="li-t">${c.cliente}</div><div class="li-s">${c.evento||'Sem evento'}${c.data_evento?' · '+c.data_evento:''} · criado ${c.criado_em?c.criado_em.slice(0,10):'—'}</div></div>
        <div style="display:flex;align-items:center;gap:8px;flex-shrink:0">
          <span class="badge ${badge}">${c.status}</span>
          <button onclick="pCot('${c.id}')" style="color:var(--gold)">${I.print}</button>
          <button onclick="delCo('${c.id}')" style="color:var(--border)">${I.trash}</button>
