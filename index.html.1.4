async function loadAll(){
  S.loading=true;render();
  try{
    const [stock,alugueis,aluguerItens,cotacoes,cotItens]=await Promise.all([
      DB.getStock(),DB.getAlugueis(),DB.getAluguerItens(),DB.getCotacoes(),DB.getCotItens()
    ]);
    S.stock=stock||[];S.alugueis=alugueis||[];S.aluguerItens=aluguerItens||[];
    S.cotacoes=cotacoes||[];S.cotItens=cotItens||[];
  }catch(e){console.error(e);}
  S.loading=false;render();
}

