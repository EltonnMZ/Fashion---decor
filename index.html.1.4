function bindLogin(){
  const go=async()=>{
    const email=document.getElementById('lu').value.trim();
    const pass=document.getElementById('lp').value.trim();
    const eEl=document.getElementById('lerr');
    if(!email||!pass){eEl.innerHTML='<div class="err">Preenche email e senha.</div>';return;}
    const btn=document.getElementById('btn-in');
    btn.disabled=true;btn.textContent='A entrar...';
    try{
      const session=await authSignIn(email,pass);
      S.session=session;
      S.user=session.user.email;
      S.role=getRole(session);
      // definir página inicial conforme role
      S.page=S.role==='admin'?'monitor':'stock';
      await loadAll();
    }catch(e){
      eEl.innerHTML=`<div class="err">${e.message}</div>`;
      btn.disabled=false;btn.textContent='ENTRAR';
    }
  };
  document.getElementById('btn-in').onclick=go;
  document.getElementById('lp').onkeydown=e=>{if(e.key==='Enter')go();};
}

