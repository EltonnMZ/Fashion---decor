function bindCotacoes(){
  const bl=document.getElementById('btn-li');
  if(bl)bl.onclick=()=>{
    const ai=document.getElementById('f-art').value;
    const qtd=Number(document.getElementById('f-qtd').value)||0;
    if(!ai){S.ierr='Seleccione um artigo.';render();return;}
    if(qtd<=0){S.ierr='Quantidade deve ser maior que zero.';render();return;}
    const art=S.stock.find(s=>s.id===ai);
    S.ierr='';S.fitens.push({artigo_id:art.id,nome:art.nome,qtd,preco:art.preco});render();
  };
  const bs=document.getElementById('btn-sv');
  if(!bs)return;
  bs.onclick=async()=>{
    const cli=document.getElementById('f-cli').value.trim();
    const evt=document.getElementById('f-evt').value.trim();
    const dt=document.getElementById('f-data').value;
    if(!cli){S.ferr='Indique o nome do cliente.';render();return;}
    if(S.fitens.length===0){S.ferr='Adicione pelo menos um artigo.';render();return;}
    const total=S.fitens.reduce((s,i)=>s+i.qtd*i.preco,0);
    bs.disabled=true;bs.textContent='A guardar...';
    try{
      const [cot]=await DB.addCotacao({cliente:cli,evento:evt||null,data_evento:dt||null,total,status:'Pendente'});
      await Promise.all(S.fitens.map(it=>DB.addCotItem({cotacao_id:cot.id,artigo_id:it.artigo_id,nome:it.nome,quantidade:it.qtd,preco_unit:it.preco})));
      S.ferr='';S.showForm=false;S.fitens=[];await loadAll();
    }catch(e){S.ferr='Erro: '+e.message;render();bs.disabled=false;}
  };
}
window.rmLi=i=>{S.fitens.splice(i,1);render();};
window.setSt=async(id,st)=>{
  try{await DB.updCotacao(id,{status:st});await loadAll();}catch(e){alert('Erro: '+e.message);}
};
window.delCo=async id=>{
  if(!confirm('Remover cotação?'))return;
  try{await DB.delCotItens(id);await DB.delCotacao(id);await loadAll();}catch(e){alert('Erro: '+e.message);}
};

