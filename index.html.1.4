<div id="pa"></div>
<div id="app"></div>
<script>
// ══════════════════════════════════════════════
// CONFIG SUPABASE
// ══════════════════════════════════════════════
const SUPA_URL="https://kapwibqcvdalcrtwyjvz.supabase.co";
const SUPA_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImthcHdpYnFjdmRhbGNydHd5anZ6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE1NzA1MDYsImV4cCI6MjA5NzE0NjUwNn0.6A-KqaR2V4e3L6qyRWGx1IG0xXbsO7qvMyVKG-1pckk";

// Token dinâmico — usa o JWT do utilizador autenticado quando disponível
function getToken(){ return S.session ? S.session.access_token : SUPA_KEY; }

async function sb(method,table,body,query){
  const url=SUPA_URL+'/rest/v1/'+table+(query?'?'+query:'');
  const r=await fetch(url,{
    method,
    headers:{
      'apikey':SUPA_KEY,
      'Authorization':'Bearer '+getToken(),
      'Content-Type':'application/json',
      'Prefer': method==='POST'?'return=representation':'',
    },
    body:body?JSON.stringify(body):undefined,
  });
  if(!r.ok){const e=await r.text();throw new Error(e);}
  if(r.status===204)return null;
  return r.json();
}

// Supabase Auth API
async function authSignIn(email,password){
  const r=await fetch(SUPA_URL+'/auth/v1/token?grant_type=password',{
    method:'POST',
    headers:{'apikey':SUPA_KEY,'Content-Type':'application/json'},
    body:JSON.stringify({email,password}),
  });
  const d=await r.json();
  if(!r.ok)throw new Error(d.error_description||d.msg||'Credenciais inválidas.');
  return d;
}
async function authSignUp(email, password){
  const r=await fetch(SUPA_URL+'/auth/v1/admin/users',{
    method:'POST',
    headers:{'apikey':SUPA_KEY,'Authorization':'Bearer '+getToken(),'Content-Type':'application/json'},
    body:JSON.stringify({email,password,email_confirm:true}),
  });
  const d=await r.json();
  if(!r.ok)throw new Error(d.msg||d.message||'Erro ao criar utilizador.');
  return d;
}
async function authUpdatePassword(newPass){
  const r=await fetch(SUPA_URL+'/auth/v1/user',{
    method:'PUT',
    headers:{'apikey':SUPA_KEY,'Authorization':'Bearer '+getToken(),'Content-Type':'application/json'},
    body:JSON.stringify({password:newPass}),
  });
  const d=await r.json();
  if(!r.ok)throw new Error(d.msg||d.message||'Erro ao actualizar senha.');
  return d;
}
async function authListUsers(){
  const r=await fetch(SUPA_URL+'/auth/v1/admin/users',{
    method:'GET',
    headers:{'apikey':SUPA_KEY,'Authorization':'Bearer '+getToken()},
  });
  const d=await r.json();
  if(!r.ok)throw new Error(d.msg||'Erro ao listar utilizadores.');
  return d.users||[];
}
async function authDeleteUser(uid){
  const r=await fetch(SUPA_URL+'/auth/v1/admin/users/'+uid,{
    method:'DELETE',
    headers:{'apikey':SUPA_KEY,'Authorization':'Bearer '+getToken()},
  });
  if(!r.ok){const d=await r.json();throw new Error(d.msg||'Erro ao remover utilizador.');}
}
async function authSetRole(email, role){
  // Usa a função SQL set_role que já criámos
  const r=await fetch(SUPA_URL+'/rest/v1/rpc/set_role',{
    method:'POST',
    headers:{'apikey':SUPA_KEY,'Authorization':'Bearer '+getToken(),'Content-Type':'application/json'},
    body:JSON.stringify({user_email:email,user_role:role}),
  });
  if(!r.ok){const d=await r.json();throw new Error(d.message||'Erro ao definir role.');}
}
async function authSignOut(){
  if(!S.session)return;
  await fetch(SUPA_URL+'/auth/v1/logout',{
    method:'POST',
    headers:{'apikey':SUPA_KEY,'Authorization':'Bearer '+S.session.access_token},
  }).catch(()=>{});
}

// Obter role do utilizador (guardada em user_metadata.role)
function getRole(session){
  try{
    const payload=JSON.parse(atob(session.access_token.split('.')[1]));
    return (payload.user_metadata && payload.user_metadata.role) || 'funcionaria';
  }catch(e){return 'funcionaria';}
}
const DB={
  getStock:()=>sb('GET','stock',null,'order=nome.asc'),
  addStock:d=>sb('POST','stock',d),
  updStock:(id,d)=>sb('PATCH','stock',d,'id=eq.'+id),
  delStock:id=>sb('DELETE','stock',null,'id=eq.'+id),
  getAlugueis:()=>sb('GET','alugueis',null,'order=criado_em.desc'),
  addAluguer:d=>sb('POST','alugueis',d),
  updAluguer:(id,d)=>sb('PATCH','alugueis',d,'id=eq.'+id),
  delAluguer:id=>sb('DELETE','alugueis',null,'id=eq.'+id),
  getCotacoes:()=>sb('GET','cotacoes',null,'order=criado_em.desc'),
  addCotacao:d=>sb('POST','cotacoes',d),
  updCotacao:(id,d)=>sb('PATCH','cotacoes',d,'id=eq.'+id),
  delCotacao:id=>sb('DELETE','cotacoes',null,'id=eq.'+id),
  getCotItens:()=>sb('GET','cotacao_itens',null,'order=cotacao_id.asc'),
  addCotItem:d=>sb('POST','cotacao_itens',d),
  delCotItens:cid=>sb('DELETE','cotacao_itens',null,'cotacao_id=eq.'+cid),
  getAluguerItens:()=>sb('GET','aluguer_itens',null,'order=aluguer_id.asc'),
  addAluguerItem:d=>sb('POST','aluguer_itens',d),
  delAluguerItens:aid=>sb('DELETE','aluguer_itens',null,'aluguer_id=eq.'+aid),
};

