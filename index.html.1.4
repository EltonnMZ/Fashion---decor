      <div style="display:flex;justify-content:space-between;padding:9px 12px;font-weight:700;color:var(--dark);font-size:14px">
        <span>Total</span><span>${fmtMZN(S.fitens.reduce((s,i)=>s+i.qtd*i.preco,0))}</span>
      </div>
    </div>`:''}
    <div style="display:flex;gap:8px">
      <button class="btn bg bsm" id="btn-sv">Guardar cotação</button>
      <button class="btn bgh bsm" onclick="S.showForm=false;render()">Cancelar</button>
