function stockHTML(isAdmin=true){
  const f=S.filtro.toLowerCase();
  const rows=S.stock.filter(s=>s.nome.toLowerCase().includes(f)||(s.categoria||'').toLowerCase().includes(f));
  const form=S.showForm?`
  <div class="fb">
    ${S.ferr?`<div class="alert">${S.ferr}</div>`:''}
    <div class="fg g2">
      <div class="s2"><label class="lbl">Nome *</label><input class="inp" id="f-nome" placeholder="ex: Cadeira Tiffany" value="${S.fd.nome||''}"/></div>
      <div><label class="lbl">Categoria</label><input class="inp" id="f-cat" placeholder="ex: Mobiliário" value="${S.fd.categoria||''}"/></div>
      <div><label class="lbl">Preço (MT)</label><input class="inp" id="f-preco" type="number" min="0" value="${S.fd.preco||''}"/></div>
      <div><label class="lbl">Qtd Cidade</label><input class="inp" id="f-a" type="number" min="0" value="${S.fd.qtd_cidade||''}"/></div>
      <div><label class="lbl">Qtd Matola</label><input class="inp" id="f-b" type="number" min="0" value="${S.fd.qtd_matola||''}"/></div>
      <div><label class="lbl">Mínimo</label><input class="inp" id="f-min" type="number" min="0" value="${S.fd.minimo||''}"/></div>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn bd bsm" id="btn-add-s">Guardar artigo</button>
      <button class="btn bgh bsm" onclick="S.showForm=false;render()">Cancelar</button>
    </div>
  </div>`:'';

  const desktopT=`<div class="card"><table class="tbl">
    <thead><tr><th>Artigo</th><th>Categoria</th><th class="r">Cidade</th><th class="r">Matola</th><th class="r">Total</th><th class="r">Mín.</th><th class="r">Preço/un.</th><th></th></tr></thead>
    <tbody>
    ${rows.map(s=>{const t=s.qtd_cidade+s.qtd_matola,lw=t<=s.minimo;return`
    <tr style="${lw?'background:#FEF5F5':''}">
      <td class="b">${s.nome} ${lw?`<span style="color:var(--danger)">${I.warn}</span>`:''}</td>
      <td class="m">${s.categoria||'—'}</td>
      <td class="r"><input type="number" min="0" value="${s.qtd_cidade}" class="qi" onchange="updQty('${s.id}','qtd_cidade',this.value)"/></td>
      <td class="r"><input type="number" min="0" value="${s.qtd_matola}" class="qi" onchange="updQty('${s.id}','qtd_matola',this.value)"/></td>
      <td class="${lw?'d':'b r'}">${t}</td>
      <td class="r m">${s.minimo}</td>
      <td class="r m">${fmtMZN(s.preco)}</td>
      <td><button onclick="delS('${s.id}')" style="color:var(--border);padding:4px">${I.trash}</button></td>
    </tr>`}).join('')}
    ${rows.length===0?`<tr><td colspan="8" style="text-align:center;padding:32px;color:var(--border)">Nenhum artigo.</td></tr>`:''}
    </tbody></table></div>`;

  const mobileC=rows.map(s=>{const t=s.qtd_cidade+s.qtd_matola,lw=t<=s.minimo;return`
  <div class="card" style="${lw?'border-color:var(--danger)':''}"><div class="cp">
    <div class="li-r"><div><div class="li-t">${s.nome} ${lw?I.warn:''}</div><div class="li-s">${s.categoria||'Geral'}</div></div>
    <button onclick="delS('${s.id}')" style="color:var(--border)">${I.trash}</button></div>
    <div class="dv"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:8px;font-size:12px">
      <div><div class="li-s">Cidade</div><input type="number" min="0" value="${s.qtd_cidade}" class="inp" style="margin-top:3px;padding:6px;font-size:16px" onchange="updQty('${s.id}','qtd_cidade',this.value)"/></div>
      <div><div class="li-s">Matola</div><input type="number" min="0" value="${s.qtd_matola}" class="inp" style="margin-top:3px;padding:6px;font-size:16px" onchange="updQty('${s.id}','qtd_matola',this.value)"/></div>
      <div><div class="li-s">Total</div><div style="font-weight:700;color:${lw?'var(--danger)':'var(--dark)'};font-size:18px;margin-top:4px">${t}</div></div>
      <div><div class="li-s">Preço</div><div style="font-size:11px;color:var(--mid);margin-top:4px">${fmtMZN(s.preco)}</div></div>
    </div>
  </div></div>`}).join('')||`<p style="text-align:center;padding:40px;color:var(--border)">Nenhum artigo.</p>`;

  return`${form}<div style="margin-bottom:12px"><input class="inp" id="fi" placeholder="🔍 Pesquisar..." value="${S.filtro}"/></div>${isMobile()?mobileC:desktopT}`;}

function bindStock(isAdmin=true){
  if(!isAdmin){const fi=document.getElementById('fi');if(fi)fi.oninput=e=>{S.filtro=e.target.value;render();};return;}
  const fi=document.getElementById('fi');
  if(fi)fi.oninput=e=>{S.filtro=e.target.value;render();};
  const b=document.getElementById('btn-add-s');
  if(!b)return;
  b.onclick=async()=>{
    const nome=document.getElementById('f-nome').value.trim();
    const cat=document.getElementById('f-cat').value.trim();
    const a=Number(document.getElementById('f-a').value)||0;
    const bv=Number(document.getElementById('f-b').value)||0;
    const min=Number(document.getElementById('f-min').value)||0;
    const preco=Number(document.getElementById('f-preco').value)||0;
    if(!nome){S.ferr='O nome do artigo é obrigatório.';render();return;}
    b.disabled=true;b.textContent='A guardar...';
    try{
      await DB.addStock({nome,categoria:cat||'Geral',qtd_cidade:a,qtd_matola:bv,minimo:min,preco});
      S.ferr='';S.showForm=false;await loadAll();
    }catch(e){S.ferr='Erro ao guardar: '+e.message;render();b.disabled=false;}
  };
}
window.delS=async id=>{
  if(!confirm('Remover artigo?'))return;
  try{await DB.delStock(id);await loadAll();}catch(e){alert('Erro: '+e.message);}
};
window.updQty=async(id,col,val)=>{
  const n=Math.max(0,Number(val)||0);
  try{await DB.updStock(id,{[col]:n});S.stock=S.stock.map(s=>s.id===id?{...s,[col]:n}:s);}
  catch(e){alert('Erro ao actualizar: '+e.message);}
};

