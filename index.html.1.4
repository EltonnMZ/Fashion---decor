let _qi=0;
function startQuotes(){
  const el=document.getElementById('quote-text');
  const au=document.getElementById('quote-author');
  if(!el||!au)return;
  _qi=Math.floor(Math.random()*QUOTES.length);
  el.textContent='\u201c'+QUOTES[_qi].t+'\u201d';
  au.textContent='— '+QUOTES[_qi].a;
