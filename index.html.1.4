function bindDefinicoes(){
  // Tab senha
  const btnPass=document.getElementById('btn-change-pass');
  if(btnPass)btnPass.onclick=async()=>{
    const p1=document.getElementById('d-pass1')?.value.trim();
    const p2=document.getElementById('d-pass2')?.value.trim();
    if(!p1||p1.length<8){S.defErr='A senha deve ter pelo menos 8 caracteres.';render();return;}
    if(p1!==p2){S.defErr='As senhas não coincidem.';render();return;}
    btnPass.disabled=true;btnPass.textContent='A actualizar...';
    try{
      await authUpdatePassword(p1);
      S.defErr='';S.defMsg='Senha actualizada com sucesso!';render();
    }catch(e){S.defErr='Erro: '+e.message;render();btnPass.disabled=false;}
  };

  // Tab utilizadores — carregar lista
  const btnLoad=document.getElementById('btn-load-users');
  if(btnLoad)btnLoad.onclick=async()=>{
    S.defLoading=true;btnLoad.textContent='A carregar...';btnLoad.disabled=true;
    try{S.defUsers=await authListUsers();S.defErr='';}
    catch(e){S.defErr='Erro ao carregar: '+e.message;}
    S.defLoading=false;render();
  };

  // Criar utilizador
  const btnCriar=document.getElementById('btn-criar-user');
  if(btnCriar)btnCriar.onclick=async()=>{
    const email=document.getElementById('d-email')?.value.trim();
    const pass=document.getElementById('d-npass')?.value.trim();
    const role=document.getElementById('d-role')?.value;
    if(!email){S.defErr='Indique o email.';render();return;}
    if(!pass||pass.length<8){S.defErr='Senha deve ter pelo menos 8 caracteres.';render();return;}
    btnCriar.disabled=true;btnCriar.textContent='A criar...';
    try{
      await authSignUp(email,pass);
      await authSetRole(email,role);
      S.defErr='';S.defMsg=`Utilizador ${email} criado com role "${role}".`;
      // Limpar campos
      document.getElementById('d-email').value='';
      document.getElementById('d-npass').value='';
      // Recarregar lista se estava aberta
      if(S.defUsers.length>0)S.defUsers=await authListUsers();
      render();
    }catch(e){S.defErr='Erro: '+e.message;render();btnCriar.disabled=false;}
  };
}

window.toggleRole=async(uid,email,currentRole)=>{
  const newRole=currentRole==='admin'?'funcionaria':'admin';
  if(!confirm(`Mudar ${email} de "${currentRole}" para "${newRole}"?`))return;
  try{
    await authSetRole(email,newRole);
    S.defUsers=await authListUsers();
    S.defMsg=`Role de ${email} actualizado para "${newRole}".`;
    S.defErr='';render();
  }catch(e){S.defErr='Erro: '+e.message;render();}
};
window.removeUser=async uid=>{
  const u=S.defUsers.find(x=>x.id===uid);
  if(!confirm(`Remover utilizador ${u?.email}? Esta acção não pode ser desfeita.`))return;
  try{
    await authDeleteUser(uid);
    S.defUsers=S.defUsers.filter(x=>x.id!==uid);
    S.defMsg='Utilizador removido.';S.defErr='';render();
  }catch(e){S.defErr='Erro: '+e.message;render();}
};

