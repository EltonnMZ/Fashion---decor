<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="Fashion Decor"/>
<meta name="theme-color" content="#2C1506"/>
<title>Fashion Decor</title>
<link rel="apple-touch-icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 180 180'%3E%3Crect width='180' height='180' rx='36' fill='%232C1506'/%3E%3Ccircle cx='90' cy='90' r='68' fill='%23D4A017'/%3E%3Ctext x='90' y='112' text-anchor='middle' font-size='56' font-weight='900' font-family='Georgia,serif' fill='%233B1F0A'%3EFD%3C/text%3E%3C/svg%3E"/>
<style>
:root{
  --bg:#E8DCC8;--sidebar:#2C1506;--card:#fff;
  --gold:#D4A017;--dark:#3B1F0A;--mid:#7A6040;
  --border:#C9B48A;--row-alt:#FDFAF4;--row-head:#F0E6CE;
  --danger:#B83A2A;--success:#4A7A3A;--warn:#A07010;
  --safe-top:env(safe-area-inset-top,0px);
  --safe-bot:env(safe-area-inset-bottom,0px);
  --sidebar-w:min(220px,30vw);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html{font-size:clamp(14px,1.8vw,16px);height:100%;}
body{height:100%;font-family:-apple-system,system-ui,"Segoe UI",sans-serif;background:var(--sidebar);overflow:hidden;}
button{cursor:pointer;border:none;background:none;font-family:inherit;touch-action:manipulation;}
input,select{font-family:inherit;font-size:16px;}
input:focus,select:focus{outline:2px solid var(--gold);outline-offset:1px;border-radius:4px;}

/* ── App ── */
#app{display:flex;flex-direction:column;height:100dvh;}

/* ── Login ── */
#login{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100dvh;background:var(--sidebar);padding:32px 20px;}
.lc{width:80px;height:80px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;}
.lc span{font-size:34px;font-weight:900;color:var(--dark);font-family:Georgia,serif;}
.lb{font-family:Georgia,serif;font-size:26px;letter-spacing:.18em;color:#fff;text-align:center;}
.ls{font-size:12px;letter-spacing:.4em;color:var(--gold);text-align:center;margin-top:-2px;}
.lcard{background:#3B1F0A;border:1px solid #5A3A18;border-radius:8px;padding:24px;width:100%;max-width:360px;margin-top:20px;}
.fl{font-size:10px;color:var(--gold);text-transform:uppercase;letter-spacing:.12em;margin-bottom:6px;display:block;}
.fr{display:flex;align-items:center;gap:8px;border-bottom:1px solid #7A6040;padding-bottom:5px;margin-bottom:16px;}
.fr input{background:transparent;border:none;color:#fff;flex:1;font-size:16px;outline:none;}
.fr svg{color:#C9B48A;flex-shrink:0;}
.btn-in{width:100%;background:var(--gold);color:var(--dark);border-radius:6px;padding:12px;font-weight:800;font-size:15px;letter-spacing:.08em;}
.err{background:#4A1010;border:1px solid #8A2020;color:#F0A0A0;font-size:12px;border-radius:4px;padding:8px 10px;margin-bottom:12px;}
.quote-box{max-width:360px;text-align:center;margin:18px auto 0;min-height:56px;display:flex;align-items:center;justify-content:center;}
.quote-text{font-family:Georgia,serif;font-size:14px;color:#C9B48A;font-style:italic;line-height:1.7;}
.quote-author{font-size:10px;color:#7A6040;letter-spacing:.08em;margin-top:4px;}

/* ── Desktop ── */
#shell{display:none;height:100dvh;}
#sidebar{width:var(--sidebar-w);background:var(--sidebar);display:flex;flex-direction:column;flex-shrink:0;border-right:1px solid #4A2A10;}
#sh{padding:20px 16px 16px;border-bottom:1px solid #4A2A10;display:flex;align-items:center;gap:10px;}
.sl{width:38px;height:38px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.sl span{font-size:15px;font-weight:900;color:var(--dark);font-family:Georgia,serif;}
.sbb{font-family:Georgia,serif;font-size:16px;color:#fff;letter-spacing:.1em;}
.ssb{font-size:9px;color:var(--gold);letter-spacing:.35em;margin-top:-2px;}
#sidebar nav{flex:1;padding-top:8px;overflow-y:auto;}
.nb{width:100%;display:flex;align-items:center;justify-content:space-between;padding:11px 16px;font-size:13px;color:#C9B48A;border-left:3px solid transparent;text-align:left;transition:background .12s;}
.nb:hover{background:#3B1F0A;color:#E8DCC8;}
.nb.active{background:#3B1F0A;color:#fff;border-left-color:var(--gold);}
.nb .ni{display:flex;align-items:center;gap:10px;}
.ndot{background:var(--danger);color:#fff;font-size:10px;border-radius:99px;padding:1px 7px;font-weight:700;}
#sf{padding:14px 16px;border-top:1px solid #4A2A10;font-size:11px;color:#7A6040;}
#sf span{color:#E8DCC8;}#sf button{color:var(--gold);font-size:11px;text-decoration:underline;margin-top:4px;display:block;}
#main{flex:1;overflow-y:auto;background:var(--bg);padding:clamp(12px,2vw,28px) clamp(14px,2.5vw,32px);}
#tbd{background:var(--card);border-bottom:1px solid var(--border);padding:12px 28px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.tbt{font-family:Georgia,serif;font-size:20px;color:var(--dark);}
.tbr{display:flex;align-items:center;gap:12px;}
.tbb{background:var(--danger);color:#fff;font-size:11px;border-radius:99px;padding:3px 10px;font-weight:700;}
.tbu{font-size:12px;color:var(--mid);}

/* ── Mobile ── */
#ms{display:none;flex-direction:column;height:100dvh;}
#tm{background:var(--sidebar);padding:calc(var(--safe-top) + 10px) 16px 10px;display:flex;align-items:center;gap:10px;flex-shrink:0;}
.tml{width:32px;height:32px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.tml span{font-size:13px;font-weight:900;color:var(--dark);font-family:Georgia,serif;}
.tmt{font-family:Georgia,serif;font-size:15px;color:#fff;flex:1;}
.tmb{background:var(--danger);color:#fff;font-size:10px;border-radius:99px;padding:2px 7px;font-weight:700;}
#cm{flex:1;overflow-y:auto;background:var(--bg);padding:12px;-webkit-overflow-scrolling:touch;}
#bn{background:var(--sidebar);border-top:1px solid #4A2A10;display:flex;padding-bottom:var(--safe-bot);flex-shrink:0;}
.bi{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:9px 4px 7px;gap:3px;font-size:10px;color:#7A6040;position:relative;}
.bi.active{color:var(--gold);}
.bi.active::after{content:'';position:absolute;top:0;left:20%;right:20%;height:2px;background:var(--gold);border-radius:0 0 3px 3px;}
.bi svg{width:22px;height:22px;}
.bdot{position:absolute;top:7px;right:calc(50% - 16px);width:7px;height:7px;background:var(--danger);border-radius:50%;}
.fab{position:fixed;bottom:calc(var(--safe-bot) + 66px);right:18px;width:52px;height:52px;border-radius:50%;background:var(--gold);color:var(--dark);font-size:26px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(0,0,0,.3);z-index:100;}

/* ── Responsive switch ── */
@media(min-width:768px){#shell{display:flex;}#ms{display:none!important;}}
@media(max-width:767px){#ms{display:flex;}#shell{display:none!important;}}

/* ── Shared ── */
.card{background:var(--card);border:1px solid var(--border);border-radius:8px;overflow:hidden;margin-bottom:12px;}
.cp{padding:12px 14px;}
.tbl{width:100%;border-collapse:collapse;font-size:13px;}
.tbl th{text-align:left;padding:10px 12px;font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--mid);background:var(--row-head);font-weight:700;white-space:nowrap;}
.tbl th.r{text-align:right;}
.tbl td{padding:10px 12px;color:var(--dark);border-bottom:1px solid #EFE5D0;vertical-align:middle;}
.tbl td.r{text-align:right;}.tbl td.m{color:var(--mid);}.tbl td.b{font-weight:700;}.tbl td.d{color:var(--danger);font-weight:700;}
.tbl tr:hover td{background:#FAF4E8;}
.li-t{font-weight:600;color:var(--dark);font-size:14px;}
.li-s{font-size:12px;color:var(--mid);margin-top:2px;}
.li-r{display:flex;justify-content:space-between;align-items:center;}
.dv{height:1px;background:#EFE5D0;margin:10px 0;}
.btn{display:inline-flex;align-items:center;gap:6px;border-radius:6px;padding:9px 16px;font-weight:700;font-size:13px;cursor:pointer;border:none;transition:opacity .12s;}
.btn:hover{opacity:.88;}
.bg{background:var(--gold);color:var(--dark);}
.bd{background:var(--dark);color:#fff;}
.bgh{background:var(--row-head);color:var(--mid);}
.bda{background:var(--danger);color:#fff;}
.bsm{padding:6px 12px;font-size:12px;}
.fb{background:#FAF4E8;border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:14px;}
.fg{display:grid;gap:10px;margin-bottom:12px;}
.g2{grid-template-columns:1fr 1fr;}
.g1{grid-template-columns:1fr;}
.s2{grid-column:span 2;}
.inp{border:1px solid var(--border);border-radius:6px;padding:9px 12px;font-size:16px;background:#fff;color:var(--dark);width:100%;}
.lbl{font-size:10px;color:var(--mid);text-transform:uppercase;letter-spacing:.09em;display:block;margin-bottom:3px;}
.badge{display:inline-block;font-size:10px;padding:3px 8px;border-radius:99px;font-weight:700;}
.bw{background:#FEF3DC;color:var(--warn);}.bo{background:#E6F0E0;color:var(--success);}.be{background:#FDEAEA;color:var(--danger);}
.alert{background:#FDEAEA;border:1px solid #E0A0A0;border-radius:6px;padding:9px 12px;font-size:12px;color:var(--danger);margin-bottom:10px;}
.kgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:16px;}
@media(min-width:768px){.kgrid{grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px;}}
.kc{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:14px;}
.kl{font-size:10px;color:var(--mid);text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px;display:flex;align-items:center;gap:5px;}
.kv{font-family:Georgia,serif;font-size:24px;color:var(--dark);}
.kv.sm{font-size:15px;}
.g2c{display:grid;grid-template-columns:1fr;gap:12px;}
@media(min-width:768px){.g2c{grid-template-columns:1fr 1fr;gap:16px;}}
.c2{grid-column:span 1;}@media(min-width:768px){.c2{grid-column:span 2;}}
.qi{width:64px;text-align:right;border:1px solid var(--border);border-radius:4px;padding:4px 6px;font-size:16px;font-family:inherit;}
.spin{display:flex;align-items:center;justify-content:center;padding:40px;color:var(--mid);font-size:13px;gap:10px;}
@media print{
  /* Esconder tudo excepto o documento */
  body > *{display:none!important;}
  #pa{
    display:block!important;
    position:absolute;left:0;top:0;
    width:100%;min-height:100%;
    padding:15mm 18mm;
    background:#fff;
    color:#3B1F0A;
    font-size:12pt;
  }
  /* Remover URL, título e data que o browser coloca */
  @page{
    size:A4 portrait;
    margin:0mm;
  }
  /* Remover URL, título e cabeçalhos que o browser adiciona */
  @page :first{ margin:0mm; }
  @page :left{ margin:0mm; }
  @page :right{ margin:0mm; }
  /* Garantir que tabelas não cortam linhas a meio */
  table{page-break-inside:auto;}
  tr{page-break-inside:avoid;page-break-after:auto;}
  thead{display:table-header-group;}
  /* Evitar corte de elementos */
  .print-block{page-break-inside:avoid;}
  /* Forçar fundo branco */
  *{-webkit-print-color-adjust:exact;print-color-adjust:exact;}
}
#pa{display:none;}
/* Instrução extra para remover headers/footers — só funciona via JS antes de imprimir */
::-webkit-scrollbar{width:4px;}::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px;}
</style>
</head>
