// ══════════════════════════════════════════════
const today=()=>new Date().toISOString().slice(0,10);
const fmtMZN=n=>Number(n||0).toLocaleString('pt-PT',{minimumFractionDigits:2,maximumFractionDigits:2})+' MT';
const isMobile=()=>window.innerWidth<768;
const ARMAZENS=['Armazém da Cidade','Armazém da Matola'];
