function monitorHTML(){
  const ec=S.alugueis.filter(a=>a.status==='Em curso');
  const pe=S.cotacoes.filter(c=>c.status==='Pendente');
  const lw=S.stock.filter(s=>(s.qtd_cidade+s.qtd_matola)<=s.minimo);
  const va=S.stock.reduce((s,x)=>s+(x.qtd_cidade+x.qtd_matola)*x.preco,0);
  const tC=S.stock.reduce((s,x)=>s+x.qtd_cidade,0);
  const tM=S.stock.reduce((s,x)=>s+x.qtd_matola,0);
  return `
<div class="kgrid">
  <div class="kc"><div class="kl">${I.stock} Artigos</div><div class="kv">${S.stock.length}</div></div>
  <div class="kc"><div class="kl">${I.aluguer} Em aluguer</div><div class="kv">${ec.length}</div></div>
  <div class="kc"><div class="kl">${I.cotacoes} Cotações pend.</div><div class="kv">${pe.length}</div></div>
  <div class="kc"><div class="kl">${I.monitor} Valor stock</div><div class="kv sm">${fmtMZN(va)}</div></div>
</div>
<div class="g2c">
  <div class="card"><div class="cp">
    <div style="font-size:11px;color:var(--mid);font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:10px;display:flex;align-items:center;gap:6px">${I.loc} Stock por armazém</div>
    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #EFE5D0"><span>Armazém da Cidade</span><strong>${tC} un.</strong></div>
    <div style="display:flex;justify-content:space-between;padding:8px 0"><span>Armazém da Matola</span><strong>${tM} un.</strong></div>
  </div></div>
  <div class="card"><div class="cp">
    <div style="font-size:11px;color:var(--danger);font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:10px;display:flex;align-items:center;gap:6px">${I.warn} Alertas — stock baixo</div>
    ${lw.length===0?`<p style="font-size:13px;color:var(--success)">✓ Todos os artigos acima do mínimo.</p>`
      :lw.map(s=>`<div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #EFE5D0;font-size:13px"><span>${s.nome}</span><span style="color:var(--danger);font-weight:700">${s.qtd_cidade+s.qtd_matola} / mín.${s.minimo}</span></div>`).join('')}
  </div></div>
  <div class="card c2"><div class="cp">
    <div style="font-size:11px;color:var(--mid);font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:10px;display:flex;align-items:center;gap:6px">${I.aluguer} Material fora do armazém</div>
    ${ec.length===0?`<p style="font-size:13px;color:var(--mid)">Nenhum material fora dos armazéns.</p>`
      :ec.map(a=>{const art=S.stock.find(s=>s.id===a.artigo_id);return`
      <div style="padding:8px 0;border-bottom:1px solid #EFE5D0">
        <div style="display:flex;justify-content:space-between;align-items:center">
          <div><strong style="font-size:13px">${art?art.nome:'—'} × ${a.quantidade}</strong> <span style="font-size:12px;color:var(--mid)">→ ${a.cliente}</span></div>
          <span style="font-size:12px;color:var(--mid)">de ${a.armazem} · dev. ${a.data_prevista||'a definir'}</span>
        </div>
      </div>`}).join('')}
  </div></div>
</div>
<div style="margin-top:18px;border:1.5px solid var(--gold);border-radius:8px;padding:14px 16px;background:rgba(212,160,23,0.07)">
  <div style="display:flex;align-items:flex-start;gap:10px">
    <span style="font-size:20px;flex-shrink:0">📋</span>
    <div>
      <div style="font-size:11px;font-weight:800;color:var(--gold);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px">NB — Política de registo de saídas</div>
      <p style="font-size:13px;color:var(--dark);line-height:1.7"><strong>Toda e qualquer saída de material do armazém deve ser registada como aluguer</strong>, independentemente da finalidade — seja para uso próprio, uso familiar, empréstimo a amigos ou qualquer outra situação não comercial.</p>
      <p style="font-size:13px;color:var(--mid);line-height:1.7;margin-top:8px">Nesses casos, preenche normalmente o registo de aluguer e indica no campo <strong style="color:var(--dark)">Evento / Local</strong> a natureza da saída, por exemplo:</p>
      <div style="margin-top:10px;display:flex;flex-direction:column;gap:6px">
        <div style="background:#fff;border:1px solid var(--border);border-radius:5px;padding:7px 12px;font-size:12px"><span style="color:var(--gold);font-weight:700">Evento / Local: </span><span style="color:var(--dark)">"Uso próprio — não pago"</span></div>
        <div style="background:#fff;border:1px solid var(--border);border-radius:5px;padding:7px 12px;font-size:12px"><span style="color:var(--gold);font-weight:700">Evento / Local: </span><span style="color:var(--dark)">"Empréstimo familiar — não pago"</span></div>
        <div style="background:#fff;border:1px solid var(--border);border-radius:5px;padding:7px 12px;font-size:12px"><span style="color:var(--gold);font-weight:700">Evento / Local: </span><span style="color:var(--dark)">"Empréstimo a [nome] — sem custo"</span></div>
      </div>
      <p style="font-size:12px;color:var(--mid);line-height:1.6;margin-top:10px">Este procedimento garante que o stock está sempre correcto e os armazéns reflectem a realidade em todo o momento.</p>
    </div>
  </div>
</div>`;}

