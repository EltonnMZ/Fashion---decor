function render(){
  const app=document.getElementById('app');
  if(!S.user){app.innerHTML=loginHTML();bindLogin();startQuotes();return;}
  if(isMobile()){app.innerHTML=mobileHTML();bindPage();}
  else{app.innerHTML=desktopHTML();bindPage();}
}
window.addEventListener('resize',()=>{if(S.user)render();});

