      ${c.itens.map(it=>`<div style="display:flex;justify-content:space-between;font-size:12px;color:var(--mid);padding:3px 0;border-bottom:1px dashed #EFE5D0"><span>${it.nome} × ${it.quantidade}</span><span>${fmtMZN(it.quantidade*it.preco_unit)}</span></div>`).join('')}
