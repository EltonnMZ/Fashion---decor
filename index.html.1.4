    <div style="border:1px solid var(--border);border-radius:6px;overflow:hidden;margin-bottom:12px">
      ${S.fitens.map((it,i)=>`
      <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;border-bottom:1px solid #EFE5D0;font-size:13px">
        <span>${it.nome} × ${it.qtd}</span>
        <span style="display:flex;align-items:center;gap:10px;color:var(--mid)">${fmtMZN(it.qtd*it.preco)}<button onclick="rmLi(${i})" style="color:var(--danger)">${I.x}</button></span>
